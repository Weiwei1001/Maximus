diff --git a/CMakeLists.txt b/CMakeLists.txt
index ca081ea..c9e2b12 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -165,8 +165,23 @@ set_target_properties(${LOADABLE_EXTENSION_NAME}
 # target_link_libraries(${EXTENSION_NAME} substrait_extension cudf::cudf
 # rmm::rmm ${NUMA_LIB}) target_link_libraries(${LOADABLE_EXTENSION_NAME}
 # substrait_extension cudf::cudf rmm::rmm)
+# Find transitive dependencies of cudf that need explicit linking
+# Search in pip/conda package paths where RAPIDS libraries are installed
+find_library(KVIKIO_LIB NAMES kvikio
+  HINTS "${CUDF_ENV_PREFIX}/lib64" "${CUDF_ENV_PREFIX}/../libkvikio/lib64"
+        "$ENV{CONDA_PREFIX}/lib" "${CMAKE_PREFIX_PATH}")
+find_library(NVCOMP_LIB NAMES nvcomp
+  HINTS "${CUDF_ENV_PREFIX}/../nvidia/libnvcomp/lib64"
+        "$ENV{CONDA_PREFIX}/lib" "${CMAKE_PREFIX_PATH}")
+
 target_link_libraries(${EXTENSION_NAME} cudf::cudf rmm::rmm ${NUMA_LIB}
                       ${LIBCONFIG++_LIBRARIES} absl::any_invocable)
+if(KVIKIO_LIB)
+  target_link_libraries(${EXTENSION_NAME} ${KVIKIO_LIB})
+endif()
+if(NVCOMP_LIB)
+  target_link_libraries(${EXTENSION_NAME} ${NVCOMP_LIB})
+endif()
 target_link_libraries(${LOADABLE_EXTENSION_NAME} cudf::cudf rmm::rmm)
 
